
.register-page.data-v-838b72c9 {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8edf5 100%);
}
.register-container.data-v-838b72c9 {
  min-height: 100vh;
  padding: 80rpx 48rpx 60rpx;
}

/* 返回按钮 */
.back-btn.data-v-838b72c9 {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
.back-icon.data-v-838b72c9 {
  width: 36rpx;
  height: 36rpx;
}

/* 标题区域 */
.header-section.data-v-838b72c9 {
  margin-bottom: 60rpx;
}
.title.data-v-838b72c9 {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}
.subtitle.data-v-838b72c9 {
  font-size: 28rpx;
  color: #8a8a8a;
}

/* 表单样式 */
.register-form.data-v-838b72c9 {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}
.input-group.data-v-838b72c9 {
  margin-bottom: 32rpx;
}
.input-wrapper.data-v-838b72c9 {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}
.input-wrapper.data-v-838b72c9:focus-within {
  background: #fff;
  box-shadow: 0 0 0 2rpx rgba(76, 175, 80, 0.2);
}
.code-wrapper.data-v-838b72c9 {
  padding-right: 12rpx;
}
.input-icon.data-v-838b72c9 {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}
.input-wrapper input.data-v-838b72c9 {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}
.input-placeholder.data-v-838b72c9 {
  color: #bbb;
  font-size: 28rpx;
}
.get-code-btn.data-v-838b72c9 {
  background: #f0f0f0;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #4caf50;
  border: none;
  min-width: 160rpx;
}
.get-code-btn.disabled.data-v-838b72c9 {
  color: #999;
  background: #f5f5f5;
}

/* 协议勾选 */
.agreement-check.data-v-838b72c9 {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}
.checkbox.data-v-838b72c9 {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ddd;
  background-color: #fff;
  transition: all 0.2s ease;
}
.checkbox.checked.data-v-838b72c9 {
  background-color: #4caf50;
  border-color: #4caf50;
}
.check-icon.data-v-838b72c9 {
  width: 28rpx;
  height: 28rpx;
}
.agreement-text.data-v-838b72c9 {
  font-size: 26rpx;
  color: #666;
}
.agreement-text .link.data-v-838b72c9,
.login-link .link.data-v-838b72c9 {
  color: #4caf50;
}

/* 注册按钮 */
.register-btn.data-v-838b72c9 {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4caf50, #2e7d32);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
}
.login-link.data-v-838b72c9 {
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

/* 弹窗样式 */
.modal-mask.data-v-838b72c9 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-container.data-v-838b72c9 {
  width: 600rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.modal-header.data-v-838b72c9 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.modal-title.data-v-838b72c9 {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}
.close-icon.data-v-838b72c9 {
  width: 40rpx;
  height: 40rpx;
}
.modal-content.data-v-838b72c9 {
  padding: 32rpx;
  max-height: 500rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}
.agreement-text.data-v-838b72c9 {
  white-space: pre-line;
}
.modal-confirm.data-v-838b72c9 {
  margin: 24rpx 32rpx 32rpx;
  height: 80rpx;
  background: #4caf50;
  border-radius: 40rpx;
  color: #fff;
  font-size: 30rpx;
  border: none;
}
